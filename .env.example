# ── Application ──────────────────────────────
APP_NAME=Momentum
APP_VERSION=1.0.0
APP_ENV=development

# ── Database ─────────────────────────────────
POSTGRES_USER=momentum_user
POSTGRES_PASSWORD=momentum_pass
POSTGRES_DB=momentum_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# DATABASE_URL=postgresql+asyncpg://momentum_user:momentum_pass@localhost:5432/momentum_db

# ── Auth & Security ─────────────────────────
# IMPORTANT: Must be 32+ characters. Auto-generated in dev if empty.
# MUST be set explicitly in production.
SECRET_KEY=replace-with-a-random-32-char-min-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM Providers ───────────────────────────
OPENROUTER_API_KEY=
GROQ_API_KEY=

# ── Rate Limiting ───────────────────────────
RATE_LIMIT_STORAGE_URL=memory://
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_SCHEDULE=10/minute

# ── CORS ────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Email / SMTP ────────────────────────────
# Leave SMTP_HOST empty to log emails to console (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@momentum-app.local
SMTP_USE_TLS=true
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_MINUTES=30
FRONTEND_URL=http://localhost:3000

# ── Monitoring ──────────────────────────────
# Sentry DSN — leave empty to disable
SENTRY_DSN=
