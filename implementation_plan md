## 9b. Per-Goal Rescue Candidate Evaluation (P1 Fix)

> [!IMPORTANT]
> Replaces user-wide `DailyLog` aggregation with goal-scoped `Task` completion query.

```python
async def _evaluate_rescue_candidate(goal: Goal, user_id: uuid.UUID, db: AsyncSession) -> bool:
    """Evaluate if a goal qualifies for rescue based on per-goal task completion rate.
    
    Returns True if the goal's completion rate is below the rescue threshold.
    """
    from sqlalchemy import func, and_

    total_result = await db.execute(
        select(func.count(Task.id)).where(
            and_(
                Task.goal_id == goal.id,
                Task.user_id == user_id,
                Task.deleted_at.is_(None),
            )
        )
    )
    total = total_result.scalar() or 0
    if total == 0:
        return False  # No tasks = no rescue needed

    completed_result = await db.execute(
        select(func.count(Task.id)).where(
            and_(
                Task.goal_id == goal.id,
                Task.user_id == user_id,
                Task.task_status == 'completed',
                Task.deleted_at.is_(None),
            )
        )
    )
    completed = completed_result.scalar() or 0
    avg_rate = completed / max(total, 1) * 100

    # D59: Externalized to config — enables product tuning without redeploy
    from app.core.config import settings
    return avg_rate < settings.rescue_threshold_pct  # Default: 30.0
```

