## 5. Corrected Milestone Progress — Cumulative Goal Lifetime

> [!IMPORTANT]
> Removed 30-day rolling window. Progress is cumulative from `goal.created_at`.
> Uses index-friendly `OR(source_date >= start, source_date IS NULL AND created_at::date >= start)` instead of `COALESCE` to preserve B-tree index usage.

```python
async def _compute_current_value(user_id, goal_id, db) -> float:
    """I42: Cumulative goal-scoped completion rate from goal creation.
    
    Uses index-friendly OR logic instead of COALESCE to allow PG to use
    B-tree indexes on source_date and created_at. source_date is guaranteed
    for recurring tasks; nullable for manual tasks where we fall back to
    created_at::date (v1 limitation).
    
    RUNBOOK: If `EXPLAIN ANALYZE` shows SeqScan on `tasks` for this query
    (likely when source_date is heavily NULL-skewed or PG statistics are stale):
      1. First: `ANALYZE tasks;` to refresh planner statistics.
      2. If SeqScan persists: add functional index:
         `CREATE INDEX ix_tasks_created_at_date ON tasks ((created_at::date))
          WHERE deleted_at IS NULL;`
      3. Monitor via: `SELECT relname, seq_scan, idx_scan FROM pg_stat_user_tables
         WHERE relname = 'tasks';`
    """
    import sqlalchemy as sa
    from sqlalchemy import func, and_, cast, Date as SADate

    goal_result = await db.execute(
        select(Goal.created_at).where(Goal.id == goal_id)
    )
    goal_created = goal_result.scalar()
    if not goal_created:
        return 0.0

    start_date = goal_created.date() if hasattr(goal_created, 'date') else goal_created

    # I42: Index-friendly date filter — allows PG to use ix_tasks_goal_id
    date_filter = sa.or_(
        Task.source_date >= start_date,
        sa.and_(Task.source_date.is_(None), cast(Task.created_at, SADate) >= start_date),
    )

    total_result = await db.execute(
        select(func.count(Task.id)).where(
            and_(
                Task.user_id == user_id,
                Task.goal_id == goal_id,
                Task.deleted_at.is_(None),
                date_filter,
            )
        )
    )
    total = total_result.scalar() or 0
    if total == 0:
        return 0.0

    completed_result = await db.execute(
        select(func.count(Task.id)).where(
            and_(
                Task.user_id == user_id,
                Task.goal_id == goal_id,
                Task.deleted_at.is_(None),
                Task.task_status == 'completed',
                date_filter,
            )
        )
    )
    completed = completed_result.scalar() or 0
    return round(completed / total * 100, 2)
```

